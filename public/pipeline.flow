    {
      "id": "node_2",
      "type": "code_editor",
      "position": {
        "x": 450,
        "y": 100
      },
      "data": {
        "title": "Data Analysis",
        "description": "Perform statistical analysis on the dataset",
        "language": "python",
        "source": [
          "# Statistical summary",
          "summary_stats = data.describe()",
          "print('Summary Statistics:')",
          "print(summary_stats)",
          "",
          "# Group by region",
          "region_summary = data.groupby('region')['sales'].agg(['mean', 'std', 'count'])",
          "print('\\nRegion Summary:')",
          "print(region_summary)",
          "",
          "# Store results",
          "analysis_results = {",
          "    'summary': summary_stats,",
          "    'by_region': region_summary",
          "}"
        ],
        "status": "completed",
        "execution_count": 2,
        "execution_timing": {
          "start_time": "2025-05-26T21:37:15Z",
          "end_time": "2025-05-26T21:37:16Z",
