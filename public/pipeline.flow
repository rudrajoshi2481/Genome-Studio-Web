      "data": {
        "title": "Data Loading",
        "description": "Load and prepare sample dataset",
        "language": "python",
        "source": [
          "import pandas as pd",
          "import numpy as np",
          "",
          "# Generate sample data",
          "np.random.seed(42)",
          "data = pd.DataFrame({",
          "    'sales': np.random.normal(1000, 200, 100),",
          "    'month': np.tile(range(1, 13), 8)[:100],",
          "    'region': np.random.choice(['North', 'South', 'East', 'West'], 100)",
          "})",
          "",
          "print(f'Dataset loaded: {data.shape[0]} rows, {data.shape[1]} columns')",
          "data.head()"
        ],
        "status": "loading",
