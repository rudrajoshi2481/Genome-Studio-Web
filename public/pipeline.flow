    {
      "id": "node_3",
      "type": "visualization",
      "position": {
        "x": 800,
        "y": 100
      },
      "data": {
        "title": "Data Visualization",
        "description": "Create charts and plots",
        "language": "python",
        "source": [
          "import matplotlib.pyplot as plt",
          "import seaborn as sns",
          "",
          "# Create subplots",
          "fig, axes = plt.subplots(2, 2, figsize=(12, 10))",
          "",
          "# Sales distribution",
          "axes[0,0].hist(data['sales'], bins=20, alpha=0.7)",
          "axes[0,0].set_title('Sales Distribution')",
          "axes[0,0].set_xlabel('Sales')",
          "",
          "# Sales by region",
          "data.boxplot(column='sales', by='region', ax=axes[0,1])",
          "axes[0,1].set_title('Sales by Region')",
          "",
          "# Sales by month",
          "monthly_avg = data.groupby('month')['sales'].mean()",
          "axes[1,0].plot(monthly_avg.index, monthly_avg.values, marker='o')",
          "axes[1,0].set_title('Average Sales by Month')",
          "axes[1,0].set_xlabel('Month')",
          "",
          "# Correlation heatmap",
          "numeric_data = data.select_dtypes(include=[np.number])",
          "sns.heatmap(numeric_data.corr(), annot=True, ax=axes[1,1])",
          "axes[1,1].set_title('Correlation Matrix')",
          "",
          "plt.tight_layout()",
          "plt.savefig('analysis_plots.png', dpi=300, bbox_inches='tight')",
          "plt.show()"
        ],
        "status": "completed",
        "execution_count": 3,
        "execution_timing": {
          "start_time": "2025-05-26T21:37:20Z",
          "end_time": "2025-05-26T21:37:23Z",
